<mujoco>
    <option gravity="0 0 -9.81" timestep="0.001"/> 
    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="-130" elevation="-20"/>
    </visual>
    
    <worldbody>
        <light diffuse=".5 .5 .5" pos="0 0 1" dir="0 0 -1"/>
        
        <body name="chassis" pos="0 0 0.04">
            <joint type="free"/>
            <inertial pos="0 0 0" mass="0.8" diaginertia="0.00181 0.00693 0.00853"/>
            <site name="imu_site" pos="0 0 0.1" size="0.01" rgba="1 0 0 1"/>
            <geom type="box" size="0.16 0.08 0.02" rgba=".9 .9 0 1"/>
            
            <geom name="ballcast" type="sphere" size="0.01" pos="0.1 0 -0.03" rgba="0.2 0.2 0.2 1" 
                  friction="0.005 0.002 0.002" contype="1" conaffinity="1"/>
            
            <body name="left-tire" pos="-0.05 0.09 0" euler='90 0 0'>
                <joint name="left-wheel" type="hinge" axis="0 0 -1" damping="0.01"/>
                <inertial pos="0 0 0" mass="0.1" diaginertia="0.000041 0.000041 0.00008"/>
                
                <geom type="cylinder" size="0.04 0.01" friction="2.5 0.05 0.05" rgba="0 .9 0 1"/>
                <site name="x_axis" pos="0.2 0 0" size="0.01" rgba="1 0 0 1"/>
                <site name="y_axis" pos="0 0.1 0" size="0.01" rgba="0 1 0 1"/>
                <site name="z_axis" pos="0 0 0.2" size="0.01" rgba="0 0 1 1"/>
            </body>
            
            <body name="right-tire" pos="-0.05 -0.09 0" euler='90 0 0'>
                <joint name="right-wheel" type="hinge" axis="0 0 -1" damping="0.01"/>
                <inertial pos="0 0 0" mass="0.1" diaginertia="0.000041 0.000041 0.00008"/>
                <geom type="cylinder" size="0.04 0.01" friction="2.5 0.05 0.05" rgba="0 .9 0 1"/>
            </body>
        </body>
    </worldbody>
    
    <sensor>
        <accelerometer name="imu_acc" site="imu_site"/>
  		<gyro name="imu_gyro" site="imu_site"/>
        <framepos objtype="geom" objname="ballcast"/>
    </sensor>
    
    <actuator>
        <velocity name="left-velocity-servo" joint="left-wheel" kv="1.5" forcelimited="true" forcerange="-0.2 0.2"/>
        <velocity name="right-velocity-servo" joint="right-wheel" kv="1.5" forcelimited="true" forcerange="-0.2 0.2"/>
    </actuator>
</mujoco>